border-radius: 19px; background: var(--branco); text-align: center; box-shadow: var(--sombra-suave); } .sensory-icon { display: grid; width: 52px; height: 52px; margin: 0 auto 12px; place-items: center; border-radius: 17px; background: var(--laranja-claro); font-size: 1.55rem; } .sensory-card:nth-child(even) .sensory-icon { background: var(--verde-claro); } .sensory-card p { margin-top: 5px; font-size: 0.82rem; } .solution-note { max-width: 730px; margin: 30px auto 0; text-align: center; } .solution-note strong { color: var(--texto); } .how-it-works { background: var(--verde-escuro); } .how-it-works h2, .how-it-works .section-heading p { color: var(--branco); } .how-it-works .section-tag { background: rgba(255, 255, 255, 0.12); color: #eff8f1; } .steps { display: grid; gap: 16px; counter-reset: passos; } .step { position: relative; padding: 26px 22px; border: 1px solid rgba(255, 255, 255, 0.12); border-radius: 21px; background: rgba(255, 255, 255, 0.08); counter-increment: passos; } .step-number { display: grid; width: 42px; height: 42px; margin-bottom: 16px; place-items: center; border-radius: 14px; background: var(--laranja); color: #4f3518; font-family: "Nunito", sans-serif; font-size: 1.1rem; font-weight: 900; } .step h3 { color: var(--branco); } .step p { margin-top: 7px; color: rgba(255, 255, 255, 0.76); font-size: 0.9rem; } .benefit { text-align: center; } .benefit-card { max-width: 850px; margin-inline: auto; padding: 34px 25px; border: 1px solid rgba(245, 169, 80, 0.25); border-radius: 28px; background: radial-gradient(circle at 10% 10%, rgba(246, 198, 91, 0.2), transparent 30%), var(--branco); box-shadow: var(--sombra); } .benefit-icon { display: grid; width: 65px; height: 65px; margin: 0 auto 20px; place-items: center; border-radius: 21px; background: var(--laranja-claro); font-size: 2rem; transform: rotate(-3deg); } .benefit-card h2 { max-width: 710px; margin-inline: auto; } .benefit-card p { max-width: 690px; margin: 18px auto 0; } .included { background: var(--branco); } .included-layout { display: grid; gap: 28px; align-items: start; } .included-list { display: grid; gap: 12px; list-style: none; } .included-list li { display: flex; gap: 12px; align-items: flex-start; color: var(--texto); font-size: 0.94rem; } .included-list svg { width: 22px; height: 22px; flex: 0 0 auto; margin-top: 2px; color: var(--verde); } .delivery-card { padding: 27px; border: 1px solid var(--borda); border-radius: var(--raio); background: var(--creme); } .delivery-card-icon { display: grid; width: 54px; height: 54px; margin-bottom: 16px; place-items: center; border-radius: 17px; background: var(--verde-claro); color: var(--verde-escuro); } .delivery-card-icon svg { width: 27px; height: 27px; } .delivery-card p { margin-top: 8px; font-size: 0.92rem; } .digital-warning { margin-top: 20px; padding: 12px 14px; border-radius: 12px; background: var(--laranja-claro); color: #715023; font-size: 0.78rem; font-weight: 600; } .for-who { padding: 55px 0; } .for-who-card { display: grid; gap: 20px; align-items: center; padding: 28px; border-radius: 26px; background: var(--verde-claro); } .for-who-card h2 { font-size: clamp(1.7rem, 5vw, 2.35rem); } .for-who-card p { margin-top: 10px; color: var(--verde-escuro); } .for-who-visual { display: grid; width: 92px; height: 92px; place-items: center; border-radius: 28px; background: var(--branco); font-size: 2.8rem; box-shadow: var(--sombra-suave); } .offer { padding-top: 35px; } .offer-card { position: relative; max-width: 800px; margin-inline: auto; overflow: hidden; padding: 37px 24px; border: 1px solid rgba(94, 146, 112, 0.2); border-radius: 30px; background: var(--branco); text-align: center; box-shadow: var(--sombra); } .offer-card::before { position: absolute; top: -80px; right: -80px; width: 190px; height: 190px; border-radius: 50%; background: var(--laranja-claro); content: ""; } .offer-card::after { position: absolute; bottom: -85px; left: -85px; width: 190px; height: 190px; border-radius: 50%; background: var(--verde-claro); content: ""; } .offer-content { position: relative; z-index: 1; } .offer-eyebrow { color: var(--verde-escuro); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; } .offer-card h2 { margin-top: 10px; } .old-price { margin-top: 25px; color: var(--texto-suave); font-size: 0.93rem; } .old-price span { text-decoration: line-through; } .current-price-label { margin-top: 4px; color: var(--texto); font-size: 0.85rem; font-weight: 600; } .current-price { margin: 3px 0 24px; color: var(--verde-escuro); font-family: "Nunito", sans-serif; font-size: clamp(2.8rem, 11vw, 4.8rem); font-weight: 900; line-height: 1; letter-spacing: -0.04em; } .offer-card .button { width: 100%; max-width: 500px; } .payment-note { margin-top: 16px; color: var(--texto-suave); font-size: 0.77rem; font-weight: 500; } .faq { background: var(--branco); } .faq-list { display: grid; max-width: 790px; margin-inline: auto; gap: 12px; } details { border: 1px solid var(--borda); border-radius: 17px; background: var(--creme); transition: background-color 0.2s ease; } details[open] { background: var(--branco); box-shadow: var(--sombra-suave); } summary { display: flex; gap: 15px; align-items: center; justify-content: space-between; padding: 19px 20px; color: var(--texto); font-family: "Nunito", sans-serif; font-size: 1rem; font-weight: 800; list-style: none; cursor: pointer; } summary::-webkit-details-marker { display: none; } summary::after { display: grid; width: 28px; height: 28px; flex: 0 0 auto; place-items: center; border-radius: 50%; background: var(--verde-claro); color: var(--verde-escuro); content: "+"; font-family: "Poppins", sans-serif; font-size: 1.1rem; transition: transform 0.2s ease; } details[open] summary::after { transform: rotate(45deg); } .faq-answer { padding: 0 20px 20px; } .faq-answer p { font-size: 0.91rem; } .final-cta { padding: 75px 0; text-align: center; } .final-cta-box { max-width: 900px; margin-inline: auto; padding: 40px 24px; border-radius: 30px; background: radial-gradient(circle at top left, rgba(246, 198, 91, 0.22), transparent 32%), var(--verde-claro); } .final-cta-box h2 { max-width: 720px; margin-inline: auto; color: var(--verde-escuro); } .final-cta-box p { max-width: 630px; margin: 17px auto 26px; color: var(--verde-escuro); } footer { padding: 25px 18px; border-top: 1px solid var(--borda); color: var(--texto-suave); font-size: 0.76rem; text-align: center; } @media (min-width: 650px) { .container { width: min(calc(100% - 56px), var(--largura)); } .button { font-size: 0.98rem; } .sensory-grid { grid-template-columns: repeat(4, 1fr); } .steps { grid-template-columns: repeat(3, 1fr); } .for-who-card { grid-template-columns: 1fr auto; padding: 35px; } .offer-card { padding: 48px 45px; } } @media (min-width: 850px) { section { padding: 90px 0; } .hero { padding: 92px 0 96px; } .problem-grid { grid-template-columns: 1.1fr 0.9fr; gap: 60px; } .included-layout { grid-template-columns: 1.25fr 0.75fr; gap: 70px; } .benefit-card { padding: 48px; } .final-cta-box { padding: 55px; } } @media (max-width: 480px) { .button { width: 100%; padding-inline: 18px; font-size: 0.84rem; } .product-showcase { margin-top: 33px; padding: 9px; border-radius: 22px; } .product-showcase img { min-height: 230px; border-radius: 15px; } .product-showcase::before { right: 11px; font-size: 0.68rem; } .sensory-card { padding-inline: 10px; } .sensory-card h3 { font-size: 1rem; } summary { font-size: 0.94rem; } } @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } *, *::before, *::after { scroll-behavior: auto !important; transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; }


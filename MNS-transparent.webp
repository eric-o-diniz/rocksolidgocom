<style> :root { --creme: #fffaf0; --creme-escuro: #fff3da; --verde: #5e9270; --verde-escuro: #386348; --verde-claro: #eaf4ec; --laranja: #f5a950; --laranja-claro: #fff0d7; --amarelo: #f6c65b; --texto: #343a36; --texto-suave: #667069; --branco: #ffffff; --borda: #e8e7df; --sombra: 0 18px 45px rgba(68, 88, 72, 0.1); --sombra-suave: 0 10px 28px rgba(68, 88, 72, 0.08); --raio: 24px; --raio-menor: 16px; --largura: 1100px; } * { box-sizing: border-box; margin: 0; padding: 0; } html { scroll-behavior: smooth; } body { background: var(--creme); color: var(--texto); font-family: "Poppins", sans-serif; font-size: 16px; line-height: 1.7; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; } img { display: block; max-width: 100%; } a { color: inherit; text-decoration: none; } button, a { -webkit-tap-highlight-color: transparent; } .container { width: min(calc(100% - 36px), var(--largura)); margin-inline: auto; } .top-bar { padding: 11px 18px; background: var(--verde-escuro); color: var(--branco); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.01em; text-align: center; } section { padding: 68px 0; } .section-tag { display: inline-flex; align-items: center; gap: 7px; margin-bottom: 16px; padding: 7px 13px; border-radius: 999px; background: var(--verde-claro); color: var(--verde-escuro); font-size: 0.76rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; } h1, h2, h3 { color: var(--texto); font-family: "Nunito", sans-serif; line-height: 1.15; } h1 { max-width: 800px; margin-inline: auto; font-size: clamp(2.25rem, 8vw, 4.4rem); font-weight: 900; letter-spacing: -0.045em; } h2 { font-size: clamp(1.85rem, 6vw, 3rem); font-weight: 900; letter-spacing: -0.035em; } h3 { font-size: 1.2rem; font-weight: 800; } p { color: var(--texto-suave); } .section-heading { max-width: 720px; margin-bottom: 34px; } .section-heading.centered { margin-inline: auto; text-align: center; } .section-heading p { margin-top: 16px; font-size: 1.02rem; } .hero { position: relative; overflow: hidden; padding: 72px 0 78px; text-align: center; } .hero::before, .hero::after { position: absolute; z-index: -1; border-radius: 50%; content: ""; filter: blur(3px); opacity: 0.55; } .hero::before { top: 20px; left: -100px; width: 260px; height: 260px; background: var(--laranja-claro); } .hero::after { right: -90px; bottom: 80px; width: 230px; height: 230px; background: var(--verde-claro); } .hero-label { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 19px; padding: 8px 15px; border: 1px solid rgba(94, 146, 112, 0.18); border-radius: 999px; background: rgba(255, 255, 255, 0.75); color: var(--verde-escuro); font-size: 0.82rem; font-weight: 700; box-shadow: var(--sombra-suave); } .hero-label span { font-size: 1rem; } .hero-subheadline { max-width: 730px; margin: 22px auto 32px; color: var(--texto-suave); font-size: clamp(1rem, 3.8vw, 1.18rem); } .hero-subheadline strong { color: var(--verde-escuro); font-weight: 700; } .product-showcase { position: relative; max-width: 780px; margin: 38px auto 34px; padding: 15px; border: 1px solid rgba(82, 102, 87, 0.1); border-radius: 30px; background: var(--branco); box-shadow: var(--sombra); } .product-showcase::before { position: absolute; top: -12px; right: 24px; padding: 7px 13px; border-radius: 999px; background: var(--laranja); color: #4c3317; content: "PDF para imprimir"; font-size: 0.75rem; font-weight: 700; box-shadow: 0 8px 18px rgba(130, 82, 25, 0.14); } .product-showcase img { width: 100%; min-height: 280px; border-radius: 19px; background: linear-gradient(135deg, var(--verde-claro), var(--laranja-claro)); object-fit: contain; } .button { display: inline-flex; min-height: 58px; align-items: center; justify-content: center; gap: 10px; padding: 16px 26px; border: 0; border-radius: 16px; background: var(--verde-escuro); color: var(--branco); font-family: "Poppins", sans-serif; font-size: 0.92rem; font-weight: 700; line-height: 1.35; text-align: center; box-shadow: 0 13px